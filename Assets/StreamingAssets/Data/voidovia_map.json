{
  "kingdomId": "known_world",
  "displayName": "Known World",
  "nodes": [
    { "id": "greyledger", "displayName": "Lik-E-Leek", "type": 0, "controllingFaction": 1, "mapPosition": { "x": 0, "y": 0 }, "isTemporary": false, "parentSettlementId": "", "hasStore": true, "hasTavern": true, "hasRecruitment": true, "hasBookStore": true, "isSkeleton": false, "flavorText": "Lord Void's capital. Renowned for its food, reviled for its women, and retarded by Ghkat Mip abuse. A beautiful city of chemically relaxed folk, protected by the iron paw of Lord Void." },
    { "id": "saltmere", "displayName": "Voi-D-Nee", "type": 1, "controllingFaction": 1, "mapPosition": { "x": -5.5, "y": 2.64 }, "isTemporary": false, "parentSettlementId": "", "hasStore": true, "hasTavern": true, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Lord Void's holiday town. Yes. A whole town to holiday. Once a year he spends the month here and enjoys his pick of the kibble. Kibble is what he calls... you guessed it. Excellent grain here by the way." },
    { "id": "red_knoll", "displayName": "Al-Javvid", "type": 1, "controllingFaction": 1, "mapPosition": { "x": 4.84, "y": 2.2 }, "isTemporary": false, "parentSettlementId": "", "hasStore": true, "hasTavern": true, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "A homage to his parents' heritage. Now home to the Void Choir. A devout lot. Better at drinking than reciting scripture." },
    { "id": "millwright", "displayName": "Tails End", "type": 1, "controllingFaction": 1, "mapPosition": { "x": 0.44, "y": -4.4 }, "isTemporary": false, "parentSettlementId": "", "hasStore": true, "hasTavern": true, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Not much to shout about. Premier spot for hunters but known to be the home of banditry for the region." },
    { "id": "bastion_holt", "displayName": "Here", "type": 2, "controllingFaction": 1, "mapPosition": { "x": 7.7, "y": 4.84 }, "isTemporary": false, "parentSettlementId": "", "hasStore": true, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "\"Hilariously\" named this due to Lord Void. After storming this settlement to liberate it from the clutches of -them-, he had a little too much of the Mip and had a go at humour." },
    { "id": "ironcauseway", "displayName": "Earl Walsall", "type": 2, "controllingFaction": 1, "mapPosition": { "x": 11.0, "y": 6.6 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Famous for having two taverns and no hospitals. Haunt of every bard, comic and storyteller within miles." },
    { "id": "ashpond", "displayName": "Beef", "type": 3, "controllingFaction": 1, "mapPosition": { "x": -3.96, "y": -3.3 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Home of the Maard Beefcow. Lord Void's choice. Bred for girth and idiocy, both of which it has in spades. Interesting Town Leader too." },
    { "id": "cinderfield", "displayName": "Gashby", "type": 3, "controllingFaction": 1, "mapPosition": { "x": -6.6, "y": -4.84 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Urgh. Not worth spending too much time here. Even the livestock look confused as to why they're here. Vaguely inhospitable but if the grain grows, the people... goes?" },
    { "id": "lowferry", "displayName": "Swarkevetton", "type": 3, "controllingFaction": 1, "mapPosition": { "x": -4.4, "y": 0.44 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Training ground of the master Tailor. Head of the village is Madame Tulsberry. Odd lady, but god can those fingers move.. to uhh make hats and that.." },
    { "id": "sheepgate", "displayName": "Hammerschmidt", "type": 3, "controllingFaction": 1, "mapPosition": { "x": 2.64, "y": -6.16 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Comprised largely of Germanic migrants. Excellent spot to grab a sausage and a stein." },
    { "id": "marshend", "displayName": "Gastledorf", "type": 3, "controllingFaction": 1, "mapPosition": { "x": -7.7, "y": 3.96 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Germanic migrant settlement with an unusually wealthy chief, Gordolf Messertonk. Worth having a chat with him if you're a fan of feeling a weighty pocket full of coin resting on your thigh." },
    { "id": "tollbar", "displayName": "Shilton", "type": 3, "controllingFaction": 1, "mapPosition": { "x": 4.4, "y": -7.04 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Standard place, standard folk." },

    { "id": "foxhollow", "displayName": "Jaro", "type": 3, "controllingFaction": 1, "mapPosition": { "x": 2.2, "y": -2.2 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Built atop a hill and home of an ancient ethnic group. Extremely friendly due to their well defended position. Many have tried to conquer this small patch of land, all have failed. Great recruits." },
    { "id": "nettlemarsh", "displayName": "Henesea", "type": 3, "controllingFaction": 1, "mapPosition": { "x": -6.6, "y": 3.3 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Sleepy little village. Sleepy due to their love of brown liquor largely." },
    { "id": "thistlewick", "displayName": "Arnold", "type": 3, "controllingFaction": 1, "mapPosition": { "x": 3.52, "y": -6.6 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Home of Karl Jones, first man to unionize the merchant escort guards. Also the first man to be publicly beheaded for a good century." },
    { "id": "ravensford", "displayName": "Pigeonbrook", "type": 3, "controllingFaction": 1, "mapPosition": { "x": 6.27, "y": 3.52 }, "isTemporary": false, "parentSettlementId": "", "hasStore": false, "hasTavern": false, "hasRecruitment": true, "hasBookStore": false, "isSkeleton": false, "flavorText": "Hunting ground to the rich. Virile woodlands surround this place and it makes for a great place to draw some boar blood." },

